<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<androidx.cardview.widget.CardView
		android:id="@+id/cardview1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_margin="10dp"
		app:cardElevation="10dp"
		app:cardCornerRadius="20dp">
		<LinearLayout
			android:id="@+id/linear1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/Share"
				android:focusable="false"
				android:layout_width="45dp"
				android:layout_height="45dp"
				android:src="@drawable/default_image"
				android:scaleType="center" />
			<TextView
				android:id="@+id/juz"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="4dp"
				android:gravity="right"
				android:text="الجزء 4"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1" />
			<TextView
				android:id="@+id/Verse_Number"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="4dp"
				android:text="97"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/Surah"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="4dp"
				android:text="سورة آل عمران"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000" />
		</LinearLayout>
	</androidx.cardview.widget.CardView>
	<androidx.cardview.widget.CardView
		android:id="@+id/cardview2"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:cardElevation="10dp"
		app:cardCornerRadius="20dp">
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/linear3"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="right|center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/Ayat"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="right"
					android:text="TextView"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#000000" />
			</LinearLayout>
			<ScrollView
				android:id="@+id/vscroll1"
				android:layout_width="match_parent"
				android:layout_height="100dp">
				<LinearLayout
					android:id="@+id/linear4"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="right|center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/Explanation"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="right"
						android:text="TextView"
						android:textSize="18sp"
						android:textStyle="bold"
						android:textColor="#000000" />
				</LinearLayout>
			</ScrollView>
			<HorizontalScrollView
				android:id="@+id/hscroll1"
				android:layout_width="match_parent"
				android:layout_height="100dp">
				<LinearLayout
					android:id="@+id/linear5"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:orientation="horizontal">
					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recyclerview1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp" />
				</LinearLayout>
			</HorizontalScrollView>
			<LinearLayout
				android:id="@+id/linear7"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="right|center_vertical"
				android:orientation="horizontal">
				<HorizontalScrollView
					android:id="@+id/hscroll2"
					android:layout_width="match_parent"
					android:layout_height="wrap_content">
					<LinearLayout
						android:id="@+id/linear8"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:gravity="right|center_vertical"
						android:orientation="horizontal">
						<LinearLayout
							android:id="@+id/linearQ"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview7"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="آخر قراءة"
								android:textSize="12sp"
								android:textColor="#000000" />
							<ImageView
								android:id="@+id/imageview3"
								android:focusable="false"
								android:layout_width="45dp"
								android:layout_height="45dp"
								android:src="@drawable/default_image"
								android:scaleType="center" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview6"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="2dp"
							android:gravity="right"
							android:text="حفظ كعلامة\n مرجعية"
							android:textSize="12sp"
							android:textStyle="bold"
							android:textColor="#000000" />
						<ImageView
							android:id="@+id/imageview2"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:src="@drawable/default_image"
							android:scaleType="center" />
						<LinearLayout
							android:id="@+id/linearM"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview9"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="ملاحظة"
								android:textSize="12sp"
								android:textColor="#000000" />
							<ImageView
								android:id="@+id/imageview5"
								android:focusable="false"
								android:layout_width="45dp"
								android:layout_height="45dp"
								android:src="@drawable/default_image"
								android:scaleType="center" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linearT"
							android:layout_width="100dp"
							android:layout_height="wrap_content"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview10"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="التفسير"
								android:textSize="12sp"
								android:textColor="#000000" />
							<ImageView
								android:id="@+id/imageview6"
								android:focusable="false"
								android:layout_width="45dp"
								android:layout_height="45dp"
								android:src="@drawable/default_image"
								android:scaleType="center" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear15"
							android:layout_width="100dp"
							android:layout_height="wrap_content"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview13"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="الأعدادات"
								android:textSize="12sp"
								android:textColor="#000000" />
							<ImageView
								android:id="@+id/imageview9"
								android:focusable="false"
								android:layout_width="45dp"
								android:layout_height="45dp"
								android:src="@drawable/default_image"
								android:scaleType="center" />
						</LinearLayout>
					</LinearLayout>
				</HorizontalScrollView>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear16"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/linear17"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/imageview10"
						android:focusable="false"
						android:layout_width="45dp"
						android:layout_height="45dp"
						android:src="@drawable/default_image"
						android:scaleType="center" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linear18"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/imageview11"
						android:focusable="false"
						android:layout_width="45dp"
						android:layout_height="45dp"
						android:src="@drawable/default_image"
						android:scaleType="center" />
					<TextView
						android:id="@+id/textview15"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="آخر قراءة"
						android:textSize="12sp"
						android:textColor="#000000" />
				</LinearLayout>
				<Button
					android:id="@+id/button1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="ماهر المعيقلي"
					android:textSize="12sp"
					android:textColor="#000000"
					android:layout_weight="1" />
				<LinearLayout
					android:id="@+id/linearS"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/imageview12"
						android:focusable="false"
						android:layout_width="45dp"
						android:layout_height="45dp"
						android:src="@drawable/default_image"
						android:scaleType="center" />
					<TextView
						android:id="@+id/textview16"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="4dp"
						android:text="أستمرار"
						android:textSize="12sp"
						android:textColor="#000000" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linearA"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/imageview13"
						android:focusable="false"
						android:layout_width="45dp"
						android:layout_height="45dp"
						android:src="@drawable/default_image"
						android:scaleType="center" />
					<TextView
						android:id="@+id/textview17"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="4dp"
						android:text="الآية"
						android:textSize="12sp"
						android:textColor="#000000" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>
